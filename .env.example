# ============================================
# Firebase Configuration
# ============================================
# Get these values from:
# Firebase Console → Project Settings → General → Your apps → SDK setup and configuration
#
# For AWS Amplify: add all VITE_* vars in
# Amplify Console → App settings → Environment variables
# (they are injected at build time by Vite)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ============================================
# Cloudinary (inspection photo uploads)
# ============================================
# 1. Create a free account at https://cloudinary.com
# 2. Go to Settings → Upload → Add upload preset
#    - Set "Signing Mode" to "Unsigned"
#    - Note the preset name
# 3. Get your Cloud Name from the Dashboard
# For AWS Amplify: also add these in Amplify Console → Environment variables
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_here

# ============================================
# Application
# ============================================
VITE_APP_NAME=QuickCheck

# ============================================
# Admin setup script (scripts/setup-admin.mjs)
# ============================================
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=ChangeMe_Strong_Password_Here!
# ADMIN_NAME=Admin
