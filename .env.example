# ============================================
# Firebase Configuration
# ============================================
# Get these values from:
# Firebase Console → Project Settings → General → Your apps → SDK setup and configuration
#
# For AWS Amplify: add all VITE_* vars in
# Amplify Console → App settings → Environment variables
# (they are injected at build time by Vite)

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ============================================
# Express Server (VIN decode proxy)
# ============================================
PORT=5001
NODE_ENV=development

# ============================================
# Application
# ============================================
VITE_APP_NAME=QuickCheck
VITE_API_BASE_URL=http://localhost:5001

# ============================================
# Production overrides (uncomment for prod)
# ============================================
# NODE_ENV=production
# VITE_API_BASE_URL=https://api.autoflopro.com

# ============================================
# Admin setup script (scripts/setup-admin.mjs)
# ============================================
# ADMIN_EMAIL=admin@yourcompany.com
# ADMIN_PASSWORD=ChangeMe_Strong_Password_Here!
# ADMIN_NAME=Admin
