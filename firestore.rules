rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Read the caller's role from their Firestore user document.
    // Uses a get() so no custom-claims setup is required.
    // Returns null (not an error) if the document doesn't exist yet.
    function userRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return (userDoc != null && userDoc.data != null) ? userDoc.data.get('role', null) : null;
    }

    // Admins have unrestricted access.
    function isAdmin() {
      return isSignedIn() && userRole() in ['admin', 'Admin'];
    }

    // Managers and service advisors can supervise inspections.
    // Includes admins so permission checks are additive.
    function isManagerOrAbove() {
      return isSignedIn() && userRole() in ['admin', 'Admin', 'manager', 'Manager', 'service_advisor', 'Service advisor'];
    }

    // Any authenticated user with a known role.
    function isKnownUser() {
      return isSignedIn() && userRole() in [
        'admin', 'Admin',
        'manager', 'Manager',
        'service_advisor', 'Service advisor',
        'technician', 'Technician'
      ];
    }

    // ─────────────────────────────────────────────────────────────
    // /inspections/{inspectionId}
    // ─────────────────────────────────────────────────────────────
    // • Admins / managers / service advisors: full CRUD on all records
    // • Technicians: full CRUD on their own records only
    // ─────────────────────────────────────────────────────────────
    match /inspections/{inspectionId} {

      // All authenticated users can read inspections (required for collection queries /
      // onSnapshot). Row-level visibility is enforced in the app layer.
      allow read: if isSignedIn();

      // Any authenticated user can create an inspection they own.
      allow create: if isKnownUser() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasAll(['userId', 'inspectionType', 'status']);

      // Admins + managers can edit anything; technicians only their own.
      allow update: if isSignedIn() &&
        (isManagerOrAbove() || isOwner(resource.data.userId)) &&
        // Prevent changing the owning userId after creation.
        request.resource.data.userId == resource.data.userId;

      // Admins can hard-delete; technicians can delete their own (e.g. drafts).
      allow delete: if isSignedIn() &&
        (isAdmin() || isOwner(resource.data.userId));
    }

    // ─────────────────────────────────────────────────────────────
    // /drafts/{draftId}
    // Draft ID format: {userId}-{inspectionType}
    // ─────────────────────────────────────────────────────────────
    match /drafts/{draftId} {

      allow read: if isSignedIn() &&
        (isManagerOrAbove() || draftId.matches(request.auth.uid + '-.*'));

      // Only the owner can write their own draft.
      allow create, update: if isKnownUser() &&
        isOwner(request.resource.data.userId) &&
        draftId.matches(request.auth.uid + '-.*');

      allow delete: if isSignedIn() &&
        (isAdmin() || draftId.matches(request.auth.uid + '-.*'));
    }

    // ─────────────────────────────────────────────────────────────
    // /users/{userId}
    // ─────────────────────────────────────────────────────────────
    // • Admins: read/write all user documents
    // • Managers: read all users (for assignment UI), edit their own
    // • Technicians: read/write their own profile only
    // • Nobody (not even users) may delete their own account here —
    //   deletion must go through Firebase Auth + Admin SDK.
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {

      allow read: if isSignedIn() &&
        (isManagerOrAbove() || isOwner(userId));

      // Self-registration on first sign-up OR first-time setup for a console-created account.
      // The caller must be creating their own document.
      // Role is allowed freely here — the app layer limits this to the registration form.
      allow create: if isSignedIn() && isOwner(userId) &&
        request.resource.data.keys().hasAll(['uid', 'email', 'role']);

      // Users may update their own profile; admins may update anyone's.
      allow update: if isSignedIn() &&
        (isAdmin() || (isOwner(userId) &&
          // Non-admins cannot escalate their own role.
          !(request.resource.data.role in ['admin', 'Admin'])));

      // Only admins can delete user documents.
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /locations/{locationId}
    // ─────────────────────────────────────────────────────────────
    // All authenticated users read locations; only admins write.
    // ─────────────────────────────────────────────────────────────
    match /locations/{locationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /inspection_schemas/{schemaId}
    // /field_registry/{fieldId}
    // ─────────────────────────────────────────────────────────────
    // Authenticated users read; only admins write (e.g. schema updates).
    // ─────────────────────────────────────────────────────────────
    match /inspection_schemas/{schemaId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /field_registry/{fieldId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────
    // /state_inspection_records/{recordId}
    // ─────────────────────────────────────────────────────────────
    match /state_inspection_records/{recordId} {
      allow read: if isSignedIn();
      allow create, update: if isKnownUser();
      allow delete: if isManagerOrAbove();
    }

    // ─────────────────────────────────────────────────────────────
    // /static_stickers/{stickerId}  (oil change stickers)
    // ─────────────────────────────────────────────────────────────
    match /static_stickers/{stickerId} {
      allow read: if isSignedIn();
      allow create, update: if isKnownUser();
      allow delete: if isManagerOrAbove();
    }

    // ─────────────────────────────────────────────────────────────
    // /label_templates/{templateId}
    // ─────────────────────────────────────────────────────────────
    match /label_templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isManagerOrAbove();
    }

    // ─────────────────────────────────────────────────────────────
    // /saved_labels/{labelId}  (generated label instances)
    // ─────────────────────────────────────────────────────────────
    match /saved_labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isKnownUser();
      allow update: if isManagerOrAbove();
      allow delete: if isManagerOrAbove();
    }

    // ─────────────────────────────────────────────────────────────
    // /audit_logs/{logId}  (security / activity audit trail)
    // ─────────────────────────────────────────────────────────────
    // Only admins can read; any authenticated user can append new entries.
    // Entries are immutable once written.
    // ─────────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // Catch-all: deny everything else
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
